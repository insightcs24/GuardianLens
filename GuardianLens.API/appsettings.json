{
  "ConnectionStrings": {
    "Default": "Data Source=guardianlens.db"
  },

  "AlertEngine": {
    "AutoTakedownThreshold": 0.97,
    "HighAlertThreshold": 0.90,
    "WatchlistThreshold": 0.82
  },

  "GoogleVision": {
    "_comment": "Use dotnet user-secrets, env GoogleVision__ApiKey, or AWS Secrets Manager — never commit real keys.",
    "ApiKey": ""
  },

  "YouTube": {
    "AccessToken": "YOUR_YOUTUBE_OAUTH_TOKEN"
  },

  "Twitter": {
    "ApiKey":    "YOUR_TWITTER_API_KEY",
    "ApiSecret": "YOUR_TWITTER_API_SECRET"
  },

  "Instagram": {
    "AccessToken": "YOUR_INSTAGRAM_ACCESS_TOKEN"
  },

  "Twilio": {
    "AccountSid": "YOUR_TWILIO_ACCOUNT_SID",
    "AuthToken":  "YOUR_TWILIO_AUTH_TOKEN",
    "FromPhone":  "+1XXXXXXXXXX"
  },

  "SendGrid": {
    "ApiKey":    "YOUR_SENDGRID_API_KEY",
    "FromEmail": "alerts@guardianlens.app",
    "FromName":  "GuardianLens Alerts"
  },

  "Notifications": {
    "EmailRecipients": [ "your-email@example.com" ],
    "SmsRecipients":   [ "+91XXXXXXXXXX" ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "Blockchain": {
    "Enabled": true,
    "Network": "Polygon Mumbai",
    "ChainId": "80001",
    "RpcUrl": "https://rpc-mumbai.maticvigil.com",
    "ContractAddress": "0xYOUR_DEPLOYED_CONTRACT_ADDRESS",
    "PrivateKey": "YOUR_WALLET_PRIVATE_KEY",
    "ExplorerBase": "https://mumbai.polygonscan.com",
    "_comment": "Leave ContractAddress and PrivateKey as-is for simulation mode. To go live: deploy blockchain/GuardianLens.sol to Polygon Mumbai via remix.ethereum.org, then fill in these values."
  }
}
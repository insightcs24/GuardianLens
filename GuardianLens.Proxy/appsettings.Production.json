{
  "Proxy": {
    "ProxyPort": 80,
    "ApiPort": 5000,
    "FrontendStaticPath": "C:\\guardianlens\\app\\frontend",
    "AcmeWebRoot": "C:\\guardianlens\\ssl\\acme-webroot",
    "AllowedOrigins": [ "*" ],
    "CertPath": "",
    "CertPassword": ""
  },

  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "guardianlens-api",
        "Match": { "Path": "/api/{**catch-all}" }
      },
      "swagger-route": {
        "ClusterId": "guardianlens-api",
        "Match": { "Path": "/swagger/{**catch-all}" }
      }
    },
    "Clusters": {
      "guardianlens-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5000/"
          }
        }
      }
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  }
}

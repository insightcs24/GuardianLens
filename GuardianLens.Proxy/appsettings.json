{
  "Proxy": {
    "ProxyPort": 80,
    "ApiPort": 5000,

    "FrontendStaticPath": "C:\\guardianlens\\app\\frontend",

    "AllowedOrigins": [ "*" ],

    "_AcmeNote": "HTTP-01 filesystem validation: win-acme --webroot must match this folder (contains .well-known).",
    "AcmeWebRoot": "C:\\guardianlens\\ssl\\acme-webroot",

    "_CertNote": "Fill CertPath/CertPassword (or set Proxy__CertPath / Proxy__CertPassword on the Windows service) after win-acme exports the PFX.",
    "CertPath": "",
    "CertPassword": ""
  },

  // ── YARP Routing Rules ──────────────────────────────────────────────────────
  // Route 1: Any request starting with /api or /swagger goes to the .NET API
  // Route 2: Everything else is served as React static files (handled in Program.cs)
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "guardianlens-api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "swagger-route": {
        "ClusterId": "guardianlens-api",
        "Match": {
          "Path": "/swagger/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "guardianlens-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5000/"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "UTF-8"
        },
        "LoadBalancingPolicy": "RoundRobin"
      }
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },

  "AllowedHosts": "*"
}
